# Your WhatsApp number (with country code, no + sign)
# Example: 628123456789 for Indonesia
ALLOWED_PHONE=628xxxxxxxxx

# CDP port (must match Antigravity's --remote-debugging-port flag)
CDP_PORT=9222

# Polling interval for response detection (milliseconds)
POLL_INTERVAL=2000

# Project directory for Antigravity
PROJECT_DIR=d:\yaru
